# Пример переменных окружения для docker-compose и локального запуска.
# Скопируйте в .env и при необходимости поправьте значения.

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=groups
# Порт, на который маппится postgres на хосте.
POSTGRES_PORT=5432

# --- Приложение --------------------------------------------------------------
# Строка подключения к БД. Для docker-compose host = имя сервиса (postgres).
DB_DSN=postgres://postgres:postgres@postgres:5432/groups?sslmode=disable

# HTTP-сервер.
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Уровень логирования: debug | info | warn | error.
LOG_LEVEL=info
